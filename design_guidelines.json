{
  "project_name": "FREE11 - Sports Prediction PWA",
  "version": "2.0",
  "theme": "dark",
  "typography": {
    "headings": {
      "family": "Bebas Neue, sans-serif",
      "weights": ["400"],
      "letter_spacing": "tracking-wide"
    },
    "body": {
      "family": "Noto Sans, sans-serif",
      "weights": ["400", "500", "700"]
    },
    "numbers": {
      "family": "Oswald, sans-serif",
      "weights": ["500", "700"]
    }
  },
  "colors": {
    "primary": "#C6A052",
    "primary_light": "#E0B84F",
    "primary_dark": "#A8863A",
    "background": "#0F1115",
    "surface": "#1B1E23",
    "surface_highlight": "#2A2D33",
    "text_primary": "#FFFFFF",
    "text_secondary": "#8A9096",
    "text_accent": "#C6A052",
    "success": "#4ade80",
    "danger": "#f87171",
    "gradients": {
      "gold_btn": "linear-gradient(135deg, #C6A052 0%, #E0B84F 100%)",
      "gold_text": "linear-gradient(135deg, #C6A052 0%, #E0B84F 50%, #C6A052 100%)",
      "surface_glow": "linear-gradient(135deg, rgba(198,160,82,0.08) 0%, rgba(15,17,21,0.95) 100%)"
    }
  },
  "layout_strategy": {
    "type": "mobile_first_pwa",
    "container_width": "max-w-md mx-auto md:max-w-2xl",
    "spacing": {
      "section_gap": "gap-4",
      "card_padding": "p-4",
      "safe_area_bottom": "pb-28"
    },
    "z_indices": {
      "bottom_nav": 50,
      "sticky_header": 40,
      "modal": 100,
      "coin_burst": 999
    }
  },
  "components": {
    "Dashboard": {
      "path": "/app/frontend/src/pages/Dashboard.js",
      "structure_order": [
        "Navbar (Top)",
        "IPLCountdown",
        "HeroSection (LiveMatchCard + QuickPredict)",
        "OnboardingChecklist (If incomplete)",
        "FirstPredictionBanner (If 0 predictions)",
        "QuickStatsBar",
        "LeaderboardPreview",
        "RecentTransactions"
      ],
      "instructions": "Reorder the dashboard to prioritize the 'Action Loop'. The Live Match Card MUST be the first element. Embed the 'QuickPredict' component directly inside the Live Match Card for 1-tap interaction."
    },
    "LiveMatchCard": {
      "features": [
        "Live Score Ticker",
        "Team Logos (Text based shortcuts if images missing)",
        "QuickPredict Widget (New Feature)"
      ],
      "quick_predict_widget": {
        "description": "Inline 2-button choice UI. DO NOT open a modal.",
        "options": ["YES (1.5x)", "NO (2.0x)"],
        "interaction": "On tap -> Show 'Bet Placed' animation -> Update user coin balance locally immediately (optimistic UI)"
      }
    },
    "OnboardingChecklist": {
      "style": "Gamified Progress Bar",
      "visuals": "Use the 'gold-shimmer' animation on the active step.",
      "behavior": "Auto-collapse completed steps. Show celebration confetti when 4/4 complete."
    },
    "BottomNavbar": {
      "path": "/app/frontend/src/components/Navbar.js",
      "items": [
        { "label": "Home", "icon": "Home", "path": "/match-centre" },
        { "label": "Predict", "icon": "Target", "path": "/predict" },
        { "label": "Rewards", "icon": "Gift", "path": "/shop" },
        { "label": "Profile", "icon": "User", "path": "/profile" }
      ],
      "style": "Glassmorphism with Gold active indicator. 4 items ONLY."
    }
  },
  "visual_enhancers": {
    "glass_effect": "backdrop-blur-md bg-opacity-90 bg-[#0F1115] border-t border-[#C6A052]/20",
    "glow_effects": "box-shadow: 0 0 20px rgba(198, 160, 82, 0.15)",
    "coin_burst_animation": "Use Framer Motion to spawn 20-30 small coin icons from the click coordinates that fall down with gravity."
  },
  "image_urls": {
    "hero_bg": "https://images.unsplash.com/photo-1750716413756-b66624b64ce4?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzOTB8MHwxfHNlYXJjaHwyfHxjcmlja2V0JTIwc3RhZGl1bSUyMG5pZ2h0JTIwbGlnaHRzJTIwbWF0Y2h8ZW58MHx8fHwxNzczNTY5OTA0fDA&ixlib=rb-4.1.0&q=85",
    "coin_icon": "https://images.unsplash.com/photo-1708714290523-e9f76878bf53?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODl8MHwxfHNlYXJjaHwzfHxnb2xkJTIwY29pbiUyMDNkJTIwcmVuZGVyJTIwc2hpbnl8ZW58MHx8fHwxNzczNTY5OTA1fDA&ixlib=rb-4.1.0&q=85",
    "trophy_icon": "https://images.unsplash.com/photo-1764408721535-2dcb912db83e?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjA1NTN8MHwxfHNlYXJjaHwxfHxnb2xkZW4lMjB0cm9waHklMjBjdXAlMjBzcG9ydHN8ZW58MHx8fHwxNzczNTY5OTA1fDA&ixlib=rb-4.1.0&q=85",
    "cheering_fans": "https://images.pexels.com/photos/15862398/pexels-photo-15862398.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
  },
  "instructions_to_main_agent": [
    "1. MODIFY Dashboard.js: Reorder components. Move 'LiveMatchHero' to the top. Add 'QuickPredict' inline component within it.",
    "2. MODIFY Navbar.js: Remove 'Games' and 'Missions' tabs. Rename/Repoint tabs to match the 4-tab requirement.",
    "3. IMPLEMENT 'QuickPredict': It must submit a prediction immediately. Mock the API call if necessary, but show the UI transition.",
    "4. IMPLEMENT 'WinCelebration': When a prediction is made, trigger a full-screen coin burst.",
    "5. ENSURE Mobile Responsiveness: The bottom nav must not overlap content. Use 'pb-28' on the main container."
  ],
  "universal_guidelines": [
    "Dark Mode ONLY.",
    "Gold (#C6A052) is for Primary Actions and Winners.",
    "Silver (#BFC3C8) is for Secondary info.",
    "Red is ONLY for Live/Danger.",
    "Green is ONLY for Success/Cash.",
    "Font 'Bebas Neue' for all Headings.",
    "No generic AI emojis."
  ]
}